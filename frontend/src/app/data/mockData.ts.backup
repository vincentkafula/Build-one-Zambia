// Mock data structure for Zambian Elections 2026

// Verification signature interface for ECZ returning officers
export interface ResultVerification {
  verified: boolean;
  returningOfficer?: {
    name: string;
    ecztId: string;
    role: string;
  };
  signature?: string; // Base64 image or signature ID
  officialDocumentUrl?: string; // URL to uploaded official ECZ form
  timestamp?: string;
  autoCalculationMatch: boolean; // Whether system calculation matches official document
  notes?: string;
}

export interface PollingStation {
  id: string;
  name: string;
  registeredVoters: number;
  totalVotes: number;
  rejectedBallots: number;
  timestamp?: string;
  results: {
    candidateId: string;
    votes: number;
  }[];
  // Polling Station level verifications
  verification?: {
    presidential?: ResultVerification;
    mp?: ResultVerification;
    mayoral?: ResultVerification;
    councillor?: ResultVerification;
  };
}

export interface Ward {
  id: string;
  name: string;
  pollingStations: PollingStation[];
  councillorCandidates?: Candidate[]; // Ward councillor candidates
  // Ward level verifications
  verification?: {
    presidential?: ResultVerification;
    mp?: ResultVerification;
    mayoral?: ResultVerification;
    councillor?: ResultVerification;
  };
}

export interface Constituency {
  id: string;
  name: string;
  wards: Ward[];
  mpCandidates: Candidate[];
  // Constituency level verifications
  verification?: {
    presidential?: ResultVerification;
    mp?: ResultVerification;
    mayoral?: ResultVerification;
  };
}

export interface District {
  id: string;
  name: string;
  constituencies: Constituency[];
  mayoralCandidates?: Candidate[];
  // District level verifications
  verification?: {
    presidential?: ResultVerification;
    mayoral?: ResultVerification;
  };
}

export interface Province {
  id: string;
  name: string;
  districts: District[];
  // Province level verifications
  verification?: {
    presidential?: ResultVerification;
  };
}

// National level interface for final presidential verification
export interface NationalResults {
  provinces: Province[];
  verification?: {
    presidential?: ResultVerification;
  };
}

export interface Candidate {
  id: string;
  name: string;
  party: string;
  partyColor: string;
  photo?: string;
  runningMate?: string;
  type: 'presidential' | 'mp' | 'mayoral' | 'councillor';
}

export interface ElectionResults {
  candidateId: string;
  votes: number;
}

