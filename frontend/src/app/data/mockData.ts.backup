    { candidateId: 'pc6', votes: Math.floor(Math.random() * 30) + 10 },
  ],
});

// Helper to create polling station with actual registered voters data
const createActualPollingStation = (id: string, name: string, registeredVoters: number): PollingStation => {
  const turnoutRate = 0.75 + Math.random() * 0.15; // 75-90% turnout
  const totalVotes = Math.floor(registeredVoters * turnoutRate);
  const rejectedBallots = Math.floor(totalVotes * 0.01); // 1% rejection rate

  // Distribute votes among 14 presidential candidates
  const validVotes = totalVotes - rejectedBallots;
  const results: { candidateId: string; votes: number }[] = [];

  // Weighted distribution favoring top candidates
  const weights = [0.35, 0.25, 0.12, 0.08, 0.06, 0.04, 0.03, 0.02, 0.015, 0.01, 0.01, 0.005, 0.005, 0.005];
  let remainingVotes = validVotes;

  for (let i = 1; i <= 14; i++) {
    const candidateId = `pc${i}`;
    const baseVotes = Math.floor(validVotes * weights[i - 1]);
    const variation = Math.floor(baseVotes * (Math.random() * 0.2 - 0.1)); // ±10% variation
    let votes = baseVotes + variation;

    if (i === 14) {
      // Last candidate gets remaining votes
      votes = remainingVotes;
    } else {
      remainingVotes -= votes;
    }

    results.push({ candidateId, votes: Math.max(0, votes) });
  }

  return {
    id,
    name,
    registeredVoters,
    totalVotes,
    rejectedBallots,
    timestamp: `2026-05-16T${String(Math.floor(Math.random() * 12) + 8).padStart(2, '0')}:${String(Math.floor(Math.random() * 60)).padStart(2, '0')}:00Z`,
    results,
  };
};

// Sample mayoral candidates
const sampleMayoralCandidates = [
  { id: 'mayor-upnd', name: 'Mayoral Candidate', party: 'UPND', partyColor: '#DC2626', type: 'mayoral' as const },
