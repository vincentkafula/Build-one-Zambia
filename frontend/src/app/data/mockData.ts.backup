// ============================================================================
// VERIFICATION HELPER FUNCTIONS
// ============================================================================

/**
 * Check if all polling stations in a ward are verified for a specific result type
 */
export function areAllStationsVerified(
  ward: Ward,
  resultType: 'presidential' | 'mp' | 'mayoral' | 'councillor'
): boolean {
  return ward.pollingStations.every(
    station => station.verification?.[resultType]?.verified === true
  );
}

/**
 * Check if all wards in a constituency are verified for a specific result type
 */
export function areAllWardsVerified(
  constituency: Constituency,
  resultType: 'presidential' | 'mp' | 'mayoral'
): boolean {
  return constituency.wards.every(
    ward => ward.verification?.[resultType]?.verified === true
  );
}

/**
 * Get verification summary for a ward
 */
export function getWardVerificationSummary(ward: Ward) {
  const total = ward.pollingStations.length;
  const verified = {
    presidential: ward.pollingStations.filter(s => s.verification?.presidential?.verified).length,
    mp: ward.pollingStations.filter(s => s.verification?.mp?.verified).length,
    mayoral: ward.pollingStations.filter(s => s.verification?.mayoral?.verified).length,
    councillor: ward.pollingStations.filter(s => s.verification?.councillor?.verified).length,
  };

  return {
    total,
    verified,
    percentages: {
      presidential: (verified.presidential / total) * 100,
      mp: (verified.mp / total) * 100,
      mayoral: (verified.mayoral / total) * 100,
      councillor: (verified.councillor / total) * 100,
    },
  };
}

/**
 * Get verification summary for a constituency
 */
export function getConstituencyVerificationSummary(constituency: Constituency) {
  const total = constituency.wards.length;
  const verified = {
    presidential: constituency.wards.filter(w => w.verification?.presidential?.verified).length,
    mp: constituency.wards.filter(w => w.verification?.mp?.verified).length,
    mayoral: constituency.wards.filter(w => w.verification?.mayoral?.verified).length,
  };

  return {
    total,
    verified,
    percentages: {
      presidential: (verified.presidential / total) * 100,
      mp: (verified.mp / total) * 100,
      mayoral: (verified.mayoral / total) * 100,
    },
  };
}

/**
 * Get all polling stations with mismatched calculations
 */
export function getStationsWithCalculationMismatches(): PollingStation[] {
  const allStations = getAllPollingStations();
  return allStations.filter(station => {
    const verifications = station.verification;
    if (!verifications) return false;

    return (
      (verifications.presidential?.verified && !verifications.presidential?.autoCalculationMatch) ||
      (verifications.mp?.verified && !verifications.mp?.autoCalculationMatch) ||
      (verifications.mayoral?.verified && !verifications.mayoral?.autoCalculationMatch) ||
      (verifications.councillor?.verified && !verifications.councillor?.autoCalculationMatch)
    );
  });
}

/**
 * Get verification progress across all levels
 */
export function getOverallVerificationProgress() {
  const allStations = getAllPollingStations();
  const totalStations = allStations.length;

  const verifiedStations = {
    presidential: allStations.filter(s => s.verification?.presidential?.verified).length,
    mp: allStations.filter(s => s.verification?.mp?.verified).length,
    mayoral: allStations.filter(s => s.verification?.mayoral?.verified).length,
    councillor: allStations.filter(s => s.verification?.councillor?.verified).length,
  };

  return {
    totalStations,
    verifiedStations,
    percentages: {
      presidential: (verifiedStations.presidential / totalStations) * 100,
      mp: (verifiedStations.mp / totalStations) * 100,
      mayoral: (verifiedStations.mayoral / totalStations) * 100,
      councillor: (verifiedStations.councillor / totalStations) * 100,
    },
  };
}

// ============================================================================
// EXISTING HELPER FUNCTIONS
// ============================================================================

// Helper functions to aggregate results
export function aggregateResults(stations: PollingStation[]): Map<string, number> {
  const totals = new Map<string, number>();

  stations.forEach(station => {
    station.results.forEach(result => {
      totals.set(result.candidateId, (totals.get(result.candidateId) || 0) + result.votes);
    });
  });

  return totals;
}

export function getAllPollingStations(): PollingStation[] {
  const stations: PollingStation[] = [];

  provinces.forEach(province => {
    province.districts.forEach(district => {
      district.constituencies.forEach(constituency => {
        constituency.wards.forEach(ward => {
          stations.push(...ward.pollingStations);
        });
      });
    });
  });

  return stations;
}

export function calculateTurnout(registeredVoters: number, totalVotes: number): number {
  if (registeredVoters === 0) return 0;
  return (totalVotes / registeredVoters) * 100;
}

export function getTotalRegisteredVoters(): number {
  return getAllPollingStations().reduce((sum, station) => sum + station.registeredVoters, 0);
}

export function getTotalVotesCast(): number {
  return getAllPollingStations().reduce((sum, station) => sum + station.totalVotes, 0);
}

export function getTotalRejectedBallots(): number {
  return getAllPollingStations().reduce((sum, station) => sum + station.rejectedBallots, 0);
}
