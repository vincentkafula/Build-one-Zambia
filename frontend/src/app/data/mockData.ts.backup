// Helper to create constituency with wards
const createConstituency = (districtId: string, constituencyName: string): Constituency => {
  const constituencyId = `${districtId}-${constituencyName.toLowerCase().replace(/\s+/g, '-')}`;

  return {
    id: constituencyId,
    name: constituencyName,
    mpCandidates: generateMPCandidates(constituencyId),
    wards: [
      {
        id: `${constituencyId}-ward1`,
        name: `${constituencyName} Ward 1`,
        pollingStations: generatePollingStations(constituencyId, `${constituencyName} Ward 1`, 2),
      },
      {
        id: `${constituencyId}-ward2`,
        name: `${constituencyName} Ward 2`,
        pollingStations: generatePollingStations(constituencyId, `${constituencyName} Ward 2`, 2),
      },
    ],
  };
};

