// Helper to create a verification object
const createVerification = (
  verified: boolean = false,
  officerName?: string,
  ecztId?: string,
  role?: string
): ResultVerification => ({
  verified,
  returningOfficer: officerName ? {
    name: officerName,
    ecztId: ecztId || `ECZ-${Math.floor(Math.random() * 100000)}`,
    role: role || 'Returning Officer',
  } : undefined,
  signature: verified ? `signature-${Math.floor(Math.random() * 1000000)}` : undefined,
  officialDocumentUrl: verified ? `/documents/ecz-form-${Math.floor(Math.random() * 1000000)}.pdf` : undefined,
  timestamp: verified ? new Date().toISOString() : undefined,
  autoCalculationMatch: verified ? Math.random() > 0.1 : false, // 90% match rate for verified results
  notes: verified ? undefined : 'Pending verification',
});

// Sample polling station generator
const generatePollingStations = (constituencyId: string, wardName: string, count: number = 2): PollingStation[] => {
  const stations: PollingStation[] = [];
  for (let i = 1; i <= count; i++) {
    stations.push({
      id: `${constituencyId}-ward-${i}-ps${i}`,
      name: `${wardName} - Station ${i}`,
      registeredVoters: Math.floor(Math.random() * 1000) + 800,
      totalVotes: Math.floor(Math.random() * 700) + 600,
      rejectedBallots: Math.floor(Math.random() * 20) + 5,
      timestamp: `2026-05-16T${String(Math.floor(Math.random() * 12) + 8).padStart(2, '0')}:${String(Math.floor(Math.random() * 60)).padStart(2, '0')}:00Z`,
      results: [
        { candidateId: 'pc1', votes: Math.floor(Math.random() * 250) + 200 },
        { candidateId: 'pc2', votes: Math.floor(Math.random() * 220) + 180 },
        { candidateId: 'pc3', votes: Math.floor(Math.random() * 80) + 40 },
        { candidateId: 'pc4', votes: Math.floor(Math.random() * 50) + 20 },
        { candidateId: 'pc5', votes: Math.floor(Math.random() * 40) + 15 },
        { candidateId: 'pc6', votes: Math.floor(Math.random() * 30) + 10 },
      ],
    });
  }
  return stations;
};

