# Build One Zambia — Backend Environment Variables
# Copy this to .env and customise before running in production

# Server port
PORT=3001

# JWT secret — CHANGE THIS to a long random string in production
JWT_SECRET=boz-jwt-secret-change-in-production-2024

# Super-admin credentials (env-based login, bypasses DB)
# CHANGE THESE before deploying
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=Admin@BOZ2024
